# ═══════════════════════════════════════
# FLAMINGOS WEBSITE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API
SUPABASE_URL=https://taxbqinbjrbrytaxxjzi.supabase.co
SUPABASE_ANON_KEY=<your_anon_key>

# Service-role key — used ONLY inside the Edge Function, never in the browser
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key>

# ── Cloudflare Turnstile ───────────────────────────────────
# Get keys at: https://dash.cloudflare.com → Turnstile
# Site key goes in config.js (frontend); secret key goes here (backend only)
TURNSTILE_SITE_KEY=<your_turnstile_site_key>
TURNSTILE_SECRET_KEY=<your_turnstile_secret_key>

# ── X (Twitter) URLs ─────────────────────────────────────
# These go in config.js on the frontend
X_PROFILE_URL=https://x.com/YOUR_HANDLE
X_POST_URL=https://x.com/YOUR_HANDLE/status/YOUR_POST_ID